PORT=8080

# ── Database ───────────────────────────────────────────────────────────────────
# Local dev (Docker Compose Postgres):
DATABASE_URL=host=postgres user=postgres password=postgres dbname=loadshare port=5432 sslmode=disable

# Staging / Production (Supabase Postgres — find under Project Settings → Database):
# DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ── Auth ───────────────────────────────────────────────────────────────────────
# Supabase → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here
